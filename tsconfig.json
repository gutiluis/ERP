{
  "compilerOptions": {
    // Emit JavaScript for this ECMAScript version (ES2020 = ES11)
    "target": "ES2020",

    // Use ECMAScript-standard class field semantics instead of legacy TypeScript behavior
    "useDefineForClassFields": true,

    // List of library files to include in compilation (ES2020 APIs + browser DOM types)
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    // does NOT affectHow you import packages. How module systems interoperate. How node_modules works
    // Do not allow JavaScript files to be compiled; TypeScript only
    "allowJs": false,

    // Skip type checking of declaration files (.d.ts); speeds up builds
    "skipLibCheck": true,

    // import something from "string"
    // Enable interoperability between CommonJS and ES modules (default imports from CJS)
    "esModuleInterop": true,

    // Module code generation: ESNext preserves import/export for the bundler
    "module": "ESnext",

    // Enable all strict type-checking options (strictNullChecks, strictFunctionTypes, etc.)
    "strict": true,

    // Require consistent casing for file names across imports (e.g. avoid MyFile vs myfile)
    "forceConsistentCasingInFileNames": true,

    // Resolve modules in a way that matches bundler behavior (e.g. Vite, webpack)
    "moduleResolution": "bundler",

    // Allow importing .json files as modules
    "resolveJsonModule": true,

    // Require each file to be compilable in isolation (needed for transpilers like Babel)
    "isolatedModules": true,

    // Vite handles output
    // Do not emit output files; type-check only (bundler handles emit). same as tsc -p tsconfig.json --noEmit
    "noEmit": true,

    // Use the new JSX transform (React 17+); no need to import React in every file
    "jsx": "react-jsx",

    // Allow importing files with non-TS/JS extensions (e.g. .css, .svg)
    "allowArbitraryExtensions": true,

    // Enforce explicit type-only imports (use "import type") and correct export/import syntax
    "verbatimModuleSyntax": true,
    //without customConditions ts guesses
    // Custom package.json "exports" conditions to resolve (e.g. "module" for ESM)
    "customConditions": ["module"],

    // Report errors for fallthrough cases in switch statements
    "noFallthroughCasesInSwitch": true,

    // Report errors on unused local variables
    "noUnusedLocals": true,

    // Base directory for resolving non-relative module names
    "baseUrl": ".",

    // Path mapping: "@/*" resolves to "./src/renderer/src/*" (e.g. @/components/Button)
    "paths": {
      "@/*": ["./src/renderer/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [{ "path": "./tsconfig.node.json" }]
}